# =============================================================================
# CuongRAG — Shared Environment Config (FREE / LOCAL-FIRST)
# Copy: cp .env.example .env
# Mặc định: không cần API key, ưu tiên chạy local để test nhanh.
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cuong_rag

# --- LLM Provider: "gemini" | "ollama" ---
# FREE mode: dùng Ollama local
LLM_PROVIDER=ollama
OLLAMA_HOST=http://host.docker.internal:11434
# 12GB VRAM quick-test: ưu tiên chạy nhanh, nhẹ
OLLAMA_MODEL=qwen3:8b
OLLAMA_ENABLE_THINKING=false

# Nếu muốn dùng Gemini (paid), comment block Ollama và bật block dưới:
# LLM_PROVIDER=gemini
# GOOGLE_AI_API_KEY=your-gemini-api-key-here
# LLM_MODEL_FAST=gemini-2.5-flash
LLM_MODEL_FAST=gemini-2.5-flash
LLM_THINKING_LEVEL=medium
LLM_MAX_OUTPUT_TOKENS=4096

# --- KG Embedding ---
# FREE mode: dùng sentence-transformers local, không cần API
KG_EMBEDDING_PROVIDER=sentence_transformers
KG_EMBEDDING_MODEL=BAAI/bge-m3
KG_EMBEDDING_DIMENSION=1024

# Tuỳ chọn khác:
# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-001
# KG_EMBEDDING_DIMENSION=3072

# --- CuongRAG Pipeline ---
CUONGRAG_ENABLED=true
CUONGRAG_ENABLE_KG=true
CUONGRAG_ENABLE_IMAGE_EXTRACTION=true
# Tắt captioning mặc định để tránh phụ thuộc model vision khi test local
CUONGRAG_ENABLE_IMAGE_CAPTIONING=false
CUONGRAG_ENABLE_TABLE_CAPTIONING=false
CUONGRAG_CHUNK_MAX_TOKENS=512
CUONGRAG_PROCESSING_TIMEOUT_MINUTES=10
CUONGRAG_INDEX_OUTPUT_DIR=/app/output
CUONGRAG_DEDUP_ENABLED=true
CUONGRAG_DEDUP_NEAR_THRESHOLD=0.85
CUONGRAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CUONGRAG_EMBEDDING_DEVICE=cuda
CUONGRAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CUONGRAG_RERANKER_DEVICE=cuda
CUONGRAG_VECTOR_PREFETCH=20
CUONGRAG_RERANKER_TOP_K=8
CUONGRAG_MIN_RELEVANCE_SCORE=0.15
CUONGRAG_KG_LANGUAGE=English

# OCR defaults an toàn cho local test (không phụ thuộc MinerU/ProtonX)
CUONGRAG_OCR_ENGINE=docling
CUONGRAG_ENABLE_PROTONX_CORRECTION=false
