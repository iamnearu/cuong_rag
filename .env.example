# =============================================================================
# CuongRAG — Shared Environment Config (new stack only)
# Copy: cp .env.example .env
# =============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cuong_rag
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cuong_rag

# --- LLM (API: Qwen3-32B) ---
LLM_PROVIDER=ollama
OLLAMA_HOST=https://mkp-api.fptcloud.com
OLLAMA_MODEL=Qwen3-32B
OLLAMA_VISION_MODEL=Qwen3-VL-8B-Instruct
OLLAMA_API_KEY=your-api-key
OLLAMA_API_TIMEOUT=60
OLLAMA_ENABLE_THINKING=false
LLM_MODEL_FAST=Qwen3-32B
LLM_THINKING_LEVEL=medium
LLM_MAX_OUTPUT_TOKENS=8192

# --- KG Embedding (API: Vietnamese_Embedding) ---
KG_EMBEDDING_PROVIDER=ollama
KG_EMBEDDING_MODEL=Vietnamese_Embedding
KG_EMBEDDING_DIMENSION=1024
KG_EMBEDDING_DEVICE=cpu

# --- CuongRAG Pipeline ---
CUONGRAG_ENABLED=true
CUONGRAG_ENABLE_KG=true
CUONGRAG_ENABLE_IMAGE_EXTRACTION=true
CUONGRAG_ENABLE_IMAGE_CAPTIONING=true
CUONGRAG_ENABLE_TABLE_CAPTIONING=true
CUONGRAG_CHUNK_MAX_TOKENS=512
CUONGRAG_PROCESSING_TIMEOUT_MINUTES=10
CUONGRAG_INDEX_OUTPUT_DIR=/app/output
CUONGRAG_DEDUP_ENABLED=true
CUONGRAG_DEDUP_NEAR_THRESHOLD=0.85
CUONGRAG_EMBEDDING_MODEL=Vietnamese_Embedding
CUONGRAG_EMBEDDING_DEVICE=cpu
CUONGRAG_EMBEDDING_API_URL=https://mkp-api.fptcloud.com/v1/embeddings
CUONGRAG_EMBEDDING_API_KEY=your-api-key
CUONGRAG_EMBEDDING_API_MODEL=Vietnamese_Embedding
CUONGRAG_EMBEDDING_API_DIMENSIONS=1024
CUONGRAG_EMBEDDING_API_ENCODING_FORMAT=float
CUONGRAG_EMBEDDING_API_TIMEOUT=30
CUONGRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CUONGRAG_RERANKER_DEVICE=cpu
CUONGRAG_RERANKER_API_MODEL=bge-reranker-v2-m3
CUONGRAG_RERANKER_API_KEY=your-api-key
CUONGRAG_RERANKER_API_URL=https://mkp-api.fptcloud.com/v1/rerank
CUONGRAG_RERANKER_API_TIMEOUT=10
CUONGRAG_STRICT_EMPTY_ON_RERANK=true
CUONGRAG_VECTOR_PREFETCH=20
CUONGRAG_RERANKER_TOP_K=8
CUONGRAG_MIN_RELEVANCE_SCORE=0.15
CUONGRAG_MULTI_HOP_ENABLED=true
CUONGRAG_CONSENSUS_TOP_K_EACH=12
CUONGRAG_CONSENSUS_MIN_INTERSECTION=2
CUONGRAG_NO_INFO_MESSAGE=Thông tin này không có trong tài liệu được cung cấp.
CUONGRAG_KG_LANGUAGE=Vietnamese
CUONGRAG_KG_EMBEDDING_BATCH_NUM=4
CUONGRAG_KG_EMBEDDING_MAX_ASYNC=1
CUONGRAG_KG_EMBEDDING_TIMEOUT_SECONDS=180
CUONGRAG_KG_LLM_TIMEOUT_SECONDS=240

# OCR (DeepSeek OCR + ProtonX correction)
CUONGRAG_OCR_ENGINE=deepseek_ocr
CUONGRAG_DEEPSEEK_OCR_MODEL=deepseek-ai/DeepSeek-OCR
CUONGRAG_DEEPSEEK_OCR_API_MODEL=DeepSeek-OCR
CUONGRAG_DEEPSEEK_OCR_API_KEY=your-api-key
CUONGRAG_DEEPSEEK_OCR_API_URL=https://mkp-api.fptcloud.com/v1/chat/completions
CUONGRAG_DEEPSEEK_OCR_API_TIMEOUT=180
CUONGRAG_DEEPSEEK_OCR_PROMPT=<image>\n<|grounding|>Convert the document to markdown.
CUONGRAG_DEEPSEEK_OCR_DPI=160
CUONGRAG_DEEPSEEK_OCR_BASE_SIZE=1024
CUONGRAG_DEEPSEEK_OCR_IMAGE_SIZE=640
CUONGRAG_DEEPSEEK_OCR_CROP_MODE=true
CUONGRAG_DEEPSEEK_OCR_TEST_COMPRESS=true
CUONGRAG_ENABLE_PROTONX_CORRECTION=false
